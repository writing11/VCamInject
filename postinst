#!/bin/sh
set -e

VCAM_DIR="/var/mobile/Library/VCam"
DEVICE_ID="$VCAM_DIR/device.id"
LICENSE_KEY="$VCAM_DIR/license.key"
TRIAL_START="$VCAM_DIR/trial.start"
VIDEO_SCALE="$VCAM_DIR/video.scale"

mkdir -p "$VCAM_DIR"

CURRENT_DEVICE_ID=""
if [ -f "$DEVICE_ID" ]; then
    CURRENT_DEVICE_ID="$(tr -cd '[:alnum:]' < "$DEVICE_ID" | tr '[:lower:]' '[:upper:]')"
fi

if [ ${#CURRENT_DEVICE_ID} -lt 16 ] || echo "$CURRENT_DEVICE_ID" | grep -q '^VCAMDEVICEIDNOTSAVED'; then
    if [ -r /dev/urandom ]; then
        od -An -N16 -tx1 /dev/urandom | tr -d ' \n' | tr '[:lower:]' '[:upper:]' > "$DEVICE_ID"
    elif command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr -d '-' | tr '[:lower:]' '[:upper:]' > "$DEVICE_ID"
    else
        date +%s%N | awk '{print "VCAM" $1 "DEVICEID"}' > "$DEVICE_ID"
    fi
fi

touch "$LICENSE_KEY" "$TRIAL_START" "$VIDEO_SCALE" >/dev/null 2>&1 || true
if [ ! -s "$VIDEO_SCALE" ]; then
    echo "1.0" > "$VIDEO_SCALE" 2>/dev/null || true
fi

chown -R mobile:mobile "$VCAM_DIR" >/dev/null 2>&1 || true
chmod 0777 "$VCAM_DIR" >/dev/null 2>&1 || true
chmod 0666 "$DEVICE_ID" >/dev/null 2>&1 || true
chmod 0666 "$LICENSE_KEY" >/dev/null 2>&1 || true
chmod 0666 "$TRIAL_START" >/dev/null 2>&1 || true
chmod 0666 "$VIDEO_SCALE" >/dev/null 2>&1 || true
chmod 0666 "$VCAM_DIR"/source.* >/dev/null 2>&1 || true

PLIST="/var/jb/Library/LaunchDaemons/com.qianmian.vcamreceiver.plist"
if [ ! -f "$PLIST" ]; then
    PLIST="/Library/LaunchDaemons/com.qianmian.vcamreceiver.plist"
fi

if [ -f "$PLIST" ]; then
    launchctl bootout system "$PLIST" >/dev/null 2>&1 || true
    launchctl bootstrap system "$PLIST" >/dev/null 2>&1 || true
    launchctl kickstart -k system/com.qianmian.vcamreceiver >/dev/null 2>&1 || true
fi

exit 0
