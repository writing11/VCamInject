#!/bin/sh
set +e

VCAM_DIR="/var/mobile/Library/VCam"
DEVICE_ID="$VCAM_DIR/device.id"
LICENSE_KEY="$VCAM_DIR/license.key"
TRIAL_START="$VCAM_DIR/trial.start"

mkdir -p "$VCAM_DIR"
touch "$LICENSE_KEY" "$TRIAL_START" >/dev/null 2>&1 || true

CURRENT_DEVICE_ID=""
if [ -f "$DEVICE_ID" ]; then
    CURRENT_DEVICE_ID="$(tr -cd '[:alnum:]' < "$DEVICE_ID" | tr '[:lower:]' '[:upper:]')"
fi

if [ ! -s "$LICENSE_KEY" ]; then
    if [ ${#CURRENT_DEVICE_ID} -lt 16 ] || echo "$CURRENT_DEVICE_ID" | grep -q '^VCAMDEVICEIDNOTSAVED'; then
        rm -f "$DEVICE_ID" >/dev/null 2>&1 || true
    fi
fi

chown -R mobile:mobile "$VCAM_DIR" >/dev/null 2>&1 || true
chmod 0777 "$VCAM_DIR" >/dev/null 2>&1 || true
chmod 0666 "$DEVICE_ID" >/dev/null 2>&1 || true
chmod 0666 "$LICENSE_KEY" >/dev/null 2>&1 || true
chmod 0666 "$TRIAL_START" >/dev/null 2>&1 || true
chmod 0666 "$VCAM_DIR"/source.* >/dev/null 2>&1 || true

JBROOT=""
if command -v jbroot >/dev/null 2>&1; then
    JBROOT="$(jbroot 2>/dev/null || true)"
fi
if [ -z "$JBROOT" ] && [ -d /var/jb ]; then
    JBROOT="/var/jb"
fi

BIN=""
for CANDIDATE in \
    "$JBROOT/usr/local/bin/vcamreceiverd" \
    /var/jb/usr/local/bin/vcamreceiverd \
    /usr/local/bin/vcamreceiverd \
    /private/preboot/*/jb-*/usr/local/bin/vcamreceiverd \
    /var/containers/Bundle/Application/.jbroot-*/usr/local/bin/vcamreceiverd
do
    if [ -n "$CANDIDATE" ] && [ -x "$CANDIDATE" ]; then
        BIN="$CANDIDATE"
        break
    fi
done

if [ -z "$BIN" ] && command -v vcamreceiverd >/dev/null 2>&1; then
    BIN="$(command -v vcamreceiverd)"
fi

if [ -z "$BIN" ]; then
    BIN="$(find /var/jb /private/preboot /var/containers -path '*usr/local/bin/vcamreceiverd' -type f 2>/dev/null | head -n 1 || true)"
fi

if [ -z "$BIN" ]; then
    BIN="/var/jb/usr/local/bin/vcamreceiverd"
fi

LAUNCH_BIN=""
for CANDIDATE in \
    "$JBROOT/usr/local/bin/vcamreceiverd_launch.sh" \
    /var/jb/usr/local/bin/vcamreceiverd_launch.sh \
    /usr/local/bin/vcamreceiverd_launch.sh \
    /private/preboot/*/jb-*/usr/local/bin/vcamreceiverd_launch.sh \
    /var/containers/Bundle/Application/.jbroot-*/usr/local/bin/vcamreceiverd_launch.sh
do
    if [ -n "$CANDIDATE" ] && [ -x "$CANDIDATE" ]; then
        LAUNCH_BIN="$CANDIDATE"
        break
    fi
done

if [ -z "$LAUNCH_BIN" ]; then
    LAUNCH_BIN="$(find /var/jb /private/preboot /var/containers -path '*usr/local/bin/vcamreceiverd_launch.sh' -type f 2>/dev/null | head -n 1 || true)"
fi

if [ -z "$LAUNCH_BIN" ]; then
    LAUNCH_BIN="$BIN"
fi

chmod 0755 "$BIN" "$LAUNCH_BIN" >/dev/null 2>&1 || true

write_plist() {
    PLIST_DIR="$1"
    [ -n "$PLIST_DIR" ] || return 1
    mkdir -p "$PLIST_DIR" >/dev/null 2>&1 || return 1
    PLIST="$PLIST_DIR/com.qianmian.vcamreceiver.plist"
    cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.qianmian.vcamreceiver</string>
    <key>ProgramArguments</key>
    <array>
        <string>$LAUNCH_BIN</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/mobile/Library/VCam/vcamreceiver.log</string>
    <key>StandardErrorPath</key>
    <string>/var/mobile/Library/VCam/vcamreceiver.err</string>
</dict>
</plist>
EOF
    chmod 0644 "$PLIST" >/dev/null 2>&1 || true
    echo "$PLIST"
    return 0
}

write_agent_plist() {
    PLIST_DIR="$1"
    [ -n "$PLIST_DIR" ] || return 1
    mkdir -p "$PLIST_DIR" >/dev/null 2>&1 || return 1
    PLIST="$PLIST_DIR/com.qianmian.vcamreceiver.mobile.plist"
    cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.qianmian.vcamreceiver.mobile</string>
    <key>ProgramArguments</key>
    <array>
        <string>$LAUNCH_BIN</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/var/mobile/Library/VCam/vcamreceiver.log</string>
    <key>StandardErrorPath</key>
    <string>/var/mobile/Library/VCam/vcamreceiver.err</string>
</dict>
</plist>
EOF
    chmod 0644 "$PLIST" >/dev/null 2>&1 || true
    echo "$PLIST"
    return 0
}

PLISTS=""
if [ -n "$JBROOT" ] && [ -d "$JBROOT" ]; then
    P="$(write_plist "$JBROOT/Library/LaunchDaemons" || true)"
    [ -n "$P" ] && PLISTS="$PLISTS $P"
fi
if [ -d /var/jb ] || [ -d /var/jb/Library ]; then
    P="$(write_plist "/var/jb/Library/LaunchDaemons" || true)"
    [ -n "$P" ] && PLISTS="$PLISTS $P"
fi
P="$(write_plist "/Library/LaunchDaemons" || true)"
[ -n "$P" ] && PLISTS="$PLISTS $P"

AGENTS=""
if [ -n "$JBROOT" ] && [ -d "$JBROOT" ]; then
    P="$(write_agent_plist "$JBROOT/Library/LaunchAgents" || true)"
    [ -n "$P" ] && AGENTS="$AGENTS $P"
fi
if [ -d /var/jb ] || [ -d /var/jb/Library ]; then
    P="$(write_agent_plist "/var/jb/Library/LaunchAgents" || true)"
    [ -n "$P" ] && AGENTS="$AGENTS $P"
fi
P="$(write_agent_plist "/Library/LaunchAgents" || true)"
[ -n "$P" ] && AGENTS="$AGENTS $P"

launchctl bootout system/com.qianmian.vcamreceiver >/dev/null 2>&1 || true
for PLIST in $PLISTS; do
    launchctl bootout system "$PLIST" >/dev/null 2>&1 || true
    launchctl bootstrap system "$PLIST" >/dev/null 2>&1 || true
done
launchctl kickstart -k system/com.qianmian.vcamreceiver >/dev/null 2>&1 || true

sleep 1
if [ -x "$BIN" ]; then
    if ! pgrep -f "vcamreceiverd" >/dev/null 2>&1; then
        launchctl bootout gui/501/com.qianmian.vcamreceiver.mobile >/dev/null 2>&1 || true
        for PLIST in $AGENTS; do
            launchctl bootout gui/501 "$PLIST" >/dev/null 2>&1 || true
            launchctl bootstrap gui/501 "$PLIST" >/dev/null 2>&1 || true
        done
        launchctl kickstart -k gui/501/com.qianmian.vcamreceiver.mobile >/dev/null 2>&1 || true
        sleep 1
    fi
fi

if [ -x "$BIN" ]; then
    if ! pgrep -f "vcamreceiverd" >/dev/null 2>&1; then
        STARTER="$VCAM_DIR/start_vcamreceiver.sh"
        {
            echo "#!/bin/sh"
            echo "\"$BIN\" >> \"$VCAM_DIR/vcamreceiver.log\" 2>> \"$VCAM_DIR/vcamreceiver.err\" &"
        } > "$STARTER" 2>/dev/null || true
        chmod 0755 "$STARTER" >/dev/null 2>&1 || true
        launchctl asuser 501 /bin/sh "$STARTER" >/dev/null 2>&1 || true
        sleep 1
    fi
fi

if [ -x "$BIN" ]; then
    if ! pgrep -f "vcamreceiverd" >/dev/null 2>&1; then
        "$BIN" >> "$VCAM_DIR/vcamreceiver.log" 2>> "$VCAM_DIR/vcamreceiver.err" &
        echo "$!" > "$VCAM_DIR/vcamreceiver.pid" 2>/dev/null || true
    fi
fi

chmod 0666 "$VCAM_DIR"/vcamreceiver.* >/dev/null 2>&1 || true
pgrep -f "vcamreceiverd" > "$VCAM_DIR/vcamreceiver.running" 2>/dev/null || true
chmod 0666 "$VCAM_DIR"/vcamreceiver.running >/dev/null 2>&1 || true

exit 0
