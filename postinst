#!/bin/sh
set -e

VCAM_DIR="/var/mobile/Library/VCam"
DEVICE_ID="$VCAM_DIR/device.id"
LICENSE_KEY="$VCAM_DIR/license.key"
TRIAL_START="$VCAM_DIR/trial.start"

mkdir -p "$VCAM_DIR"
touch "$LICENSE_KEY" "$TRIAL_START" >/dev/null 2>&1 || true

CURRENT_DEVICE_ID=""
if [ -f "$DEVICE_ID" ]; then
    CURRENT_DEVICE_ID="$(tr -cd '[:alnum:]' < "$DEVICE_ID" | tr '[:lower:]' '[:upper:]')"
fi

if [ ! -s "$LICENSE_KEY" ]; then
    if [ ${#CURRENT_DEVICE_ID} -lt 16 ] || echo "$CURRENT_DEVICE_ID" | grep -q '^VCAMDEVICEIDNOTSAVED'; then
        rm -f "$DEVICE_ID" >/dev/null 2>&1 || true
    fi
fi

chown -R mobile:mobile "$VCAM_DIR" >/dev/null 2>&1 || true
chmod 0777 "$VCAM_DIR" >/dev/null 2>&1 || true
chmod 0666 "$DEVICE_ID" >/dev/null 2>&1 || true
chmod 0666 "$LICENSE_KEY" >/dev/null 2>&1 || true
chmod 0666 "$TRIAL_START" >/dev/null 2>&1 || true
chmod 0666 "$VCAM_DIR"/source.* >/dev/null 2>&1 || true

JBROOT=""
if command -v jbroot >/dev/null 2>&1; then
    JBROOT="$(jbroot 2>/dev/null || true)"
fi
if [ -z "$JBROOT" ] && [ -d /var/jb ]; then
    JBROOT="/var/jb"
fi

BIN=""
for CANDIDATE in \
    "$JBROOT/usr/local/bin/vcamreceiverd" \
    /var/jb/usr/local/bin/vcamreceiverd \
    /usr/local/bin/vcamreceiverd \
    /private/preboot/*/jb-*/usr/local/bin/vcamreceiverd \
    /var/containers/Bundle/Application/.jbroot-*/usr/local/bin/vcamreceiverd
do
    if [ -n "$CANDIDATE" ] && [ -x "$CANDIDATE" ]; then
        BIN="$CANDIDATE"
        break
    fi
done

if [ -z "$BIN" ] && command -v vcamreceiverd >/dev/null 2>&1; then
    BIN="$(command -v vcamreceiverd)"
fi

if [ -z "$BIN" ]; then
    BIN="/var/jb/usr/local/bin/vcamreceiverd"
fi

chmod 0755 "$BIN" >/dev/null 2>&1 || true

PLIST_DIR=""
if [ -n "$JBROOT" ] && [ -d "$JBROOT" ]; then
    PLIST_DIR="$JBROOT/Library/LaunchDaemons"
elif [ -d /var/jb ] || [ -d /var/jb/Library ]; then
    PLIST_DIR="/var/jb/Library/LaunchDaemons"
else
    PLIST_DIR="/Library/LaunchDaemons"
fi
mkdir -p "$PLIST_DIR"
PLIST="$PLIST_DIR/com.qianmian.vcamreceiver.plist"

cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.qianmian.vcamreceiver</string>
    <key>ProgramArguments</key>
    <array>
        <string>$BIN</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/mobile/Library/VCam/vcamreceiver.log</string>
    <key>StandardErrorPath</key>
    <string>/var/mobile/Library/VCam/vcamreceiver.err</string>
</dict>
</plist>
EOF

chmod 0644 "$PLIST" >/dev/null 2>&1 || true
launchctl bootout system/com.qianmian.vcamreceiver >/dev/null 2>&1 || true
launchctl bootout system "$PLIST" >/dev/null 2>&1 || true
launchctl bootstrap system "$PLIST" >/dev/null 2>&1 || true
launchctl kickstart -k system/com.qianmian.vcamreceiver >/dev/null 2>&1 || true

exit 0
